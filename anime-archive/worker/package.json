{
  "name": "anime-archive-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply anime-archive-db",
    "db:migrate:local": "wrangler d1 migrations apply anime-archive-db --local",
    "db:seed": "wrangler d1 execute anime-archive-db --file=./migrations/seed.sql",
    "db:seed:local": "wrangler d1 execute anime-archive-db --local --file=./migrations/seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": "^0.36.0",
    "jose": "^5.9.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241201.0",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.28.0",
    "wrangler": "^3.90.0",
    "typescript": "^5.6.0"
  }
}
